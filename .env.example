# Adapter credentials (supply the ones you use)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
CURSOR_API_KEY=...
OPENAI_API_KEY=...              # used by codex-cli

# Local OpenAI-compatible adapter (Ollama, vLLM, LM Studio, ...)
SYGIL_LOCAL_OAI_URL=http://localhost:11434/v1
SYGIL_LOCAL_OAI_KEY=ollama

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Telemetry (default off)
SYGIL_TELEMETRY=off

# Dev-only (web UI hot-reload against running CLI)
SYGIL_UI_DEV=0
