{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "nodes": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "adapter": {
            "type": "string",
            "enum": [
              "claude-sdk",
              "claude-cli",
              "codex",
              "cursor",
              "echo",
              "gemini-cli",
              "local-oai"
            ]
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disallowedTools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputDir": {
            "type": "string"
          },
          "expectedOutputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputSchema": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "maxTurns": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "maxBudgetUsd": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "timeoutMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "idleTimeoutMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "sandbox": {
            "type": "string",
            "enum": [
              "read-only",
              "workspace-write",
              "full-access"
            ]
          },
          "providers": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "adapter": {
                  "type": "string",
                  "enum": [
                    "claude-sdk",
                    "claude-cli",
                    "codex",
                    "cursor",
                    "echo",
                    "gemini-cli",
                    "local-oai"
                  ]
                },
                "model": {
                  "type": "string",
                  "minLength": 1
                },
                "priority": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "adapter",
                "priority"
              ],
              "additionalProperties": false
            }
          },
          "modelTier": {
            "type": "string",
            "enum": [
              "cheap",
              "smart"
            ]
          },
          "writesContext": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "readsContext": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "retryPolicy": {
            "type": "object",
            "properties": {
              "maxAttempts": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9007199254740991
              },
              "initialDelayMs": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "backoffMultiplier": {
                "type": "number",
                "minimum": 1
              },
              "maxDelayMs": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "retryableErrors": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "transport",
                    "rate_limit",
                    "server_5xx"
                  ]
                }
              }
            },
            "required": [
              "maxAttempts",
              "initialDelayMs",
              "backoffMultiplier",
              "maxDelayMs"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "adapter",
          "model",
          "role",
          "prompt"
        ],
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "gate": {
            "type": "object",
            "properties": {
              "conditions": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "exit_code"
                        },
                        "value": {
                          "type": "integer",
                          "minimum": -9007199254740991,
                          "maximum": 9007199254740991
                        }
                      },
                      "required": [
                        "type",
                        "value"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "file_exists"
                        },
                        "path": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "path"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "regex"
                        },
                        "filePath": {
                          "type": "string",
                          "minLength": 1
                        },
                        "pattern": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "filePath",
                        "pattern"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "script"
                        },
                        "path": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "path"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "human_review"
                        },
                        "prompt": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "spec_compliance"
                        },
                        "specPath": {
                          "type": "string",
                          "minLength": 1
                        },
                        "mode": {
                          "type": "string",
                          "enum": [
                            "exact",
                            "superset"
                          ]
                        }
                      },
                      "required": [
                        "type",
                        "specPath",
                        "mode"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            },
            "required": [
              "conditions"
            ],
            "additionalProperties": false
          },
          "contract": {
            "type": "object",
            "properties": {
              "outputSchema": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              },
              "inputMapping": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "isLoopBack": {
            "type": "boolean"
          },
          "maxRetries": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "id",
          "from",
          "to"
        ],
        "additionalProperties": false
      }
    },
    "parameters": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "boolean"
            ]
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "default": {}
        },
        "required": [
          "type"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "name",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "$id": "https://raw.githubusercontent.com/akshatvasisht/sygil/main/docs/workflow.schema.json",
  "title": "Sygil Workflow Graph"
}
